        local opts="--help "
        opts+='--config '
        opts+='--env '
        opts+='-e '
        opts+='--env-file '
        opts+='--help '
        opts+='-h '
        opts+='--list-commands '
        opts+='--list-flags '
        opts+='--output '
        opts+='--verbose '
        opts+='-v '
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
        ;;    "testapp hello")
        # Completions for hello
        local opts="--help "
        opts+='--config '
        opts+='--env '
        opts+='-e '
        opts+='--env-file '
        opts+='--help '
        opts+='-h '
        opts+='--list-commands '
        opts+='--list-flags '
        opts+='--output '
        opts+='--verbose '
        opts+='-v '
        COMPREPLY=( $(compgen -W "$opts" -- "$cur") )
        ;;    "testapp project")
        # Completions for project
        local opts="--help "
        opts+='--config '
        opts+='--env '
        opts+='-e '
        opts+='--env-file '
        opts+='--help '
        opts+='-h '
        opts+='--list-commands '
        opts+='--list-flags '
        opts+='--output '
        opts+='--verbose '
        opts+='-v '
        opts+='--all '
        opts+='--namespace '
        local subcmds="repo "
        COMPREPLY=( $(compgen -W "$opts $subcmds" -- "$cur") )
        ;;    "testapp project repo")
        # Completions for repo
        local opts="--help "
        opts+='--config '
        opts+='--env '
        opts+='-e '
        opts+='--env-file '
        opts+='--help '
        opts+='-h '
        opts+='--list-commands '
        opts+='--list-flags '
        opts+='--output '
        opts+='--verbose '
        opts+='-v '
        opts+='--all '
        opts+='--namespace '
        opts+='--force '
        opts+='--region '
        local subcmds="create "
        COMPREPLY=( $(compgen -W "$opts $subcmds" -- "$cur") )
        ;;    "testapp project repo create")
        # Completions for create
        local opts="--help "
        opts+='--config '
        opts+='--env '
        opts+='-e '
        opts+='--env-file '
        opts+='--help '
        opts+='-h '
        opts+='--list-commands '
