        opts+='--list-commands '
        opts+='--list-flags '
        opts+='--output '
        opts+='--verbose '
        opts+='-v '
        local subcmds="completion hello project "
        COMPREPLY=( $(compgen -W "$opts $subcmds" -- "$cur") )
        ;;    "testapp completion")
