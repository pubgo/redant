                '-h:SHOW HELP FOR COMMAND.'
                '--list-commands:LIST ALL COMMANDS, INCLUDING SUBCOMMANDS.'
                '--list-flags:LIST ALL FLAGS.'
                '--list-format:OUTPUT FORMAT FOR --LIST-COMMANDS AND --LIST-FLAGS.'
